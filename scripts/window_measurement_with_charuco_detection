import cv2
import numpy as np
import os
from pathlib import Path
from ultralytics import YOLO
import config.settings as settings
import scripts.utils as utils


class WindowMeasurementSystem:
    def __init__(self):
        """Initialize the window measurement system."""
        # Use settings for ChArUco board specifications
        self.board_cols = settings.CHARUCOBOARD_COLCOUNT
        self.board_rows = settings.CHARUCOBOARD_ROWCOUNT
        self.square_size_mm = settings.SQUARE_LENGTH * 1000  # Convert from meters to mm
        self.marker_size_mm = settings.MARKER_LENGTH * 1000  # Convert from meters to mm

        # Use existing ChArUco board from utils
        self.charuco_board = utils.create_charuco_board()

        # Use existing detector parameters from utils
        self.detector_params = utils.get_detector_params()

        # Load YOLO model using existing utils function
        # We pass a dummy test dir since we don't need validation for measurement
        self.yolo_model, self.model_path = utils.load_model_and_validate_paths(".")

        # Measurement accuracy target
        self.target_accuracy_mm = 10

    def calculate_pixel_to_mm_ratio(self, charuco_corners, charuco_ids):
        """
        Calculate pixel-to-millimeter ratio using detected ChArUco corners.

        Returns:
            - pixels_per_mm: Ratio of pixels to millimeters
            - success: Boolean indicating calculation success
        """
        if charuco_corners is None or len(charuco_corners) < 4:
            return None, False

        # Calculate distances between adjacent corners
        pixel_distances = []
        known_distances_mm = []

        for i in range(len(charuco_ids)):
            for j in range(i + 1, len(charuco_ids)):
                id1, id2 = charuco_ids[i][0], charuco_ids[j][0]

                # Calculate row and column positions of corners
                row1, col1 = divmod(id1, self.board_cols - 1)
                row2, col2 = divmod(id2, self.board_cols - 1)

                # Check if corners are adjacent (horizontally or vertically)
                if (abs(row1 - row2) == 1 and col1 == col2) or (
                    abs(col1 - col2) == 1 and row1 == row2
                ):
                    # Calculate pixel distance
                    p1 = charuco_corners[i][0]
                    p2 = charuco_corners[j][0]
                    pixel_dist = np.linalg.norm(p1 - p2)

                    pixel_distances.append(pixel_dist)
                    known_distances_mm.append(self.square_size_mm)

        if len(pixel_distances) == 0:
            print("No adjacent corner pairs found for calibration")
            return None, False

        # Calculate average pixels per mm
        ratios = [pd / kd for pd, kd in zip(pixel_distances, known_distances_mm)]
        pixels_per_mm = np.mean(ratios)

        print(f"Calculated {len(pixel_distances)} distance measurements")
        print(f"Pixels per mm: {pixels_per_mm:.3f}")
        print(f"Calibration std deviation: {np.std(ratios):.3f}")

        return pixels_per_mm, True

    def detect_windows(self, image):
        """
        Detect windows using the trained YOLO model.

        Returns:
            - detections: List of window detections with coordinates
        """
        results = self.yolo_model.predict(
            task="obb",
            source=image,
            conf=settings.CONFIDENCE_THRESHOLD,
            iou=settings.IOU_THRESHOLD,
            save=False,
            verbose=False,
            max_det=5,
        )

        result = results[0]
        detections = []

        if len(result.obb) > 0:
            for i, box in enumerate(result.obb):
                confidence = float(box.conf[0])
                obb_coords = box.xyxyxyxy[0].cpu().numpy()

                detection = {
                    "id": i + 1,
                    "confidence": confidence,
                    "coordinates": obb_coords,
                    "bbox_type": "obb",
                }
                detections.append(detection)

        print(f"Detected {len(detections)} windows")
        return detections

    def calculate_window_dimensions(self, detection, pixels_per_mm):
        """
        Calculate real-world dimensions of a window detection.

        Returns:
            - width_mm: Window width in millimeters
            - height_mm: Window height in millimeters
        """
        coords = detection["coordinates"]

        # For OBB, we have 4 corner points: (x1,y1), (x2,y2), (x3,y3), (x4,y4)
        points = coords.reshape(4, 2)

        # Calculate edge lengths
        edge_lengths_pixels = []
        for i in range(4):
            p1 = points[i]
            p2 = points[(i + 1) % 4]  # Next point (wrapping around)
            edge_length = np.linalg.norm(p2 - p1)
            edge_lengths_pixels.append(edge_length)

        # Assuming rectangular window, opposite sides should be similar
        # Group into width and height
        edge_lengths_pixels.sort()
        height_pixels = np.mean([edge_lengths_pixels[0], edge_lengths_pixels[2]])
        width_pixels = np.mean([edge_lengths_pixels[1], edge_lengths_pixels[3]])

        # Convert to millimeters
        height_mm = height_pixels / pixels_per_mm
        width_mm = width_pixels / pixels_per_mm

        return width_mm, height_mm

    def process_image(self, image_path, output_dir=None):
        """
        Main function to process a single image and measure windows.

        Args:
            image_path: Path to input image
            output_dir: Directory to save annotated results (optional)

        Returns:
            results: Dictionary containing measurements and metadata
        """
        # Load image
        image = cv2.imread(str(image_path))
        if image is None:
            raise ValueError(f"Could not load image: {image_path}")

        print(f"Processing image: {Path(image_path).name}")
        print(f"Image dimensions: {image.shape[1]}x{image.shape[0]} pixels")

        # Detect ChArUco board using existing utils function
        # Create visualization directory if it doesn't exist
        vis_dir = os.path.join(output_dir or "temp_measurement", "charuco_detection")
        os.makedirs(vis_dir, exist_ok=True)

        marker_ids, charuco_corners, charuco_ids = utils.detect_charuco_board(
            image,
            settings.ARUCO_DICT,
            self.charuco_board,
            self.detector_params,
            vis_dir,
            image_path,
        )

        charuco_success = (
            marker_ids is not None
            and charuco_corners is not None
            and charuco_ids is not None
        )

        if not charuco_success:
            return {
                "success": False,
                "error": "Failed to detect ChArUco board",
                "image_path": str(image_path),
            }

        # Calculate pixel-to-mm ratio
        pixels_per_mm, calibration_success = self.calculate_pixel_to_mm_ratio(
            charuco_corners, charuco_ids
        )

        if not calibration_success:
            return {
                "success": False,
                "error": "Failed to calculate pixel-to-mm ratio",
                "image_path": str(image_path),
            }

        # Detect windows
        window_detections = self.detect_windows(image)

        if not window_detections:
            return {
                "success": True,
                "warning": "No windows detected",
                "pixels_per_mm": pixels_per_mm,
                "windows": [],
                "image_path": str(image_path),
            }

        # Calculate dimensions for each window
        results = {
            "success": True,
            "image_path": str(image_path),
            "pixels_per_mm": pixels_per_mm,
            "calibration_accuracy_target_mm": self.target_accuracy_mm,
            "windows": [],
        }

        for detection in window_detections:
            width_mm, height_mm = self.calculate_window_dimensions(
                detection, pixels_per_mm
            )

            window_result = {
                "id": detection["id"],
                "confidence": detection["confidence"],
                "width_mm": width_mm,
                "height_mm": height_mm,
                "width_pixels": width_mm * pixels_per_mm,
                "height_pixels": height_mm * pixels_per_mm,
                "coordinates": detection["coordinates"].tolist(),
            }

            results["windows"].append(window_result)

            print(f"Window {detection['id']}:")
            print(f"  Confidence: {detection['confidence']:.3f}")
            print(f"  Width: {width_mm:.1f} mm")
            print(f"  Height: {height_mm:.1f} mm")

        # Save annotated image if output directory provided
        if output_dir:
            self.save_annotated_image(image, results, output_dir)

        return results

    def save_annotated_image(self, image, results, output_dir):
        """Save image with annotations showing measurements."""
        os.makedirs(output_dir, exist_ok=True)

        annotated_image = image.copy()

        # Draw window measurements
        for window in results["windows"]:
            coords = np.array(window["coordinates"]).reshape(4, 2).astype(int)

            # Draw OBB
            cv2.polylines(annotated_image, [coords], True, (0, 255, 0), 2)

            # Add text with measurements
            center = coords.mean(axis=0).astype(int)
            text = f"W:{window['width_mm']:.0f}mm H:{window['height_mm']:.0f}mm"

            cv2.putText(
                annotated_image,
                text,
                (center[0] - 50, center[1]),
                cv2.FONT_HERSHEY_SIMPLEX,
                0.6,
                (0, 255, 0),
                2,
            )

        # Save annotated image
        filename = f"measured_{Path(results['image_path']).name}"
        output_path = os.path.join(output_dir, filename)
        cv2.imwrite(output_path, annotated_image)

        print(f"Annotated image saved: {output_path}")


def measure_window_from_image(image_path, output_dir=None):
    """
    Convenience function to measure windows in a single image.

    Args:
        image_path: Path to the image file
        output_dir: Directory to save results (optional)

    Returns:
        Measurement results dictionary
    """
    system = WindowMeasurementSystem()
    return system.process_image(image_path, output_dir)


if __name__ == "__main__":
    # Example usage
    import sys

    if len(sys.argv) != 2:
        print("Usage: python window_measurement.py <image_path>")
        sys.exit(1)

    image_path = sys.argv[1]
    output_dir = "measurement_results"

    try:
        results = measure_window_from_image(image_path, output_dir)

        if results["success"]:
            print(f"\n=== MEASUREMENT RESULTS ===")
            print(f"Image: {results['image_path']}")
            print(f"Calibration: {results['pixels_per_mm']:.3f} pixels/mm")
            print(f"Windows detected: {len(results['windows'])}")

            for window in results["windows"]:
                print(f"\nWindow {window['id']}:")
                print(
                    f"  Dimensions: {window['width_mm']:.1f} x {window['height_mm']:.1f} mm"
                )
                print(f"  Confidence: {window['confidence']:.3f}")
        else:
            print(f"Measurement failed: {results.get('error', 'Unknown error')}")

    except Exception as e:
        print(f"Error processing image: {e}")
        sys.exit(1)
